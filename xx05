+<!DOCTYPE html>
+<html>
+<head>
+<meta charset="utf-8">
+<style>
+  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap');
+  * { margin: 0; padding: 0; box-sizing: border-box; }
+  body {
+    width: 1200px;
+    height: 630px;
+    background: linear-gradient(135deg, #1B3A5C 0%, #244B73 100%);
+    font-family: 'Noto Sans JP', sans-serif;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    color: white;
+    overflow: hidden;
+    position: relative;
+  }
+  .container { text-align: center; padding: 60px; }
+  .badges { display: flex; gap: 12px; justify-content: center; margin-bottom: 32px; }
+  .badge { background: rgba(255,255,255,0.15); padding: 8px 20px; border-radius: 100px; font-size: 16px; }
+  h1 { font-size: 52px; font-weight: 700; line-height: 1.3; margin-bottom: 24px; letter-spacing: 0.02em; }
+  h1 span { color: #7DCEA0; }
+  .sub { font-size: 22px; opacity: 0.8; line-height: 1.6; }
+  .corner { position: absolute; bottom: 40px; right: 60px; font-size: 18px; opacity: 0.5; }
+</style>
+</head>
+<body>
+  <div class="container">
+    <div class="badges">
+      <div class="badge">🏛️ 行政書士監修</div>
+      <div class="badge">無料</div>
+      <div class="badge">1分で完了</div>
+    </div>
+    <h1>あなたの会社が使える<br><span>補助金</span>、1分で見つかります</h1>
+    <div class="sub">5つの質問に答えるだけ。個人情報の入力は不要です。</div>
+  </div>
+  <div class="corner">補助金診断</div>
+</body>
+</html>
